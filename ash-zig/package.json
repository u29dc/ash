{
  "name": "ash",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/u29dc/ash"
  },
  "scripts": {
    "dev----------------------------------": "",
    "dev": "zig build run",
    "build--------------------------------": "",
    "build": "zig build",
    "build:release": "zig build -Doptimize=ReleaseFast",
    "build:small": "zig build -Doptimize=ReleaseSmall",
    "test---------------------------------": "",
    "test": "zig build test",
    "check--------------------------------": "",
    "util:format": "zig fmt src/",
    "util:lint": "zig fmt --check src/ && zig build",
    "util:clean": "rm -rf zig-out zig-cache .zig-cache",
    "util:check": "STATUS=0; bun run util:lint || STATUS=1; bun run test || STATUS=1; exit $STATUS"
  },
  "devDependencies": {}
}
